---
import '../styles/global.css';
const { title, description, image } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | AnythingFromAmerica.com</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  {image && <meta property="og:image" content={image} />}
  <meta name="twitter:card" content="summary_large_image" />


  <!-- JSON-LD structured data for LLM + Google findability -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "AnythingFromAmerica.com",
    "description": "U.S. export broker connecting global buyers with American goods — from components to aircraft.",
    "url": "https://anythingfromamerica.com",
    "telephone": "+1-817-715-1156",
    "email": "info@anythingfromamerica.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Dallas",
      "addressRegion": "TX",
      "addressCountry": "US"
    },
    "areaServed": "Worldwide",
    "serviceType": "U.S. Export Brokerage"
  }
  </script>
</head>
<body>

<!-- ===== NAVIGATION ===== -->
<header id="site-header">
  <nav class="nav-inner container">
    <a href="/" class="nav-logo">
      <span class="logo-main">Anything</span><span class="logo-accent">FromAmerica</span><span class="logo-dot">.com</span>
    </a>

    <button class="nav-toggle" id="nav-toggle" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <ul class="nav-links" id="nav-links">
      <li><a href="/" class="nav-link">Home</a></li>
      <li><a href="/why-usa" class="nav-link">Why USA?</a></li>
      <li><a href="/services" class="nav-link">Services</a></li>
      <li><a href="/team" class="nav-link">Team</a></li>
      <li><a href="/faq" class="nav-link">FAQ</a></li>
      <li><a href="/contact" class="nav-cta btn btn-primary">Get a Quote</a></li>
    </ul>
  </nav>
</header>

<main>
  <slot />
</main>

<!-- ===== FOOTER ===== -->
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">Anything<span>FromAmerica</span>.com</div>
        <p>From micro to mighty — your trusted U.S. export partner connecting global buyers with American goods since day one.</p>
        <div class="footer-contact-row">
          <a href="mailto:info@anythingfromamerica.com">info@anythingfromamerica.com</a>
          <a href="tel:+18177151156">+1 (817) 715-1156</a>
          <span>Dallas, Texas, USA</span>
        </div>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="/why-usa">Why From USA</a></li>
          <li><a href="/services">Our Services</a></li>
          <li><a href="/team">Our Team</a></li>
          <li><a href="/faq">FAQ</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="/services#aviation">Aviation & Aircraft</a></li>
          <li><a href="/services#industrial">Industrial Equipment</a></li>
          <li><a href="/services#consumer">Consumer Goods</a></li>
          <li><a href="/services#financing">Buy Now, Pay Later</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Get Started</h4>
        <ul>
          <li><a href="/contact">Request a Quote</a></li>
          <li><a href="/contact#inquiry">Submit an Inquiry</a></li>
        </ul>
        <a href="/contact" class="btn btn-primary" style="margin-top:1.25rem;width:fit-content">Contact Us</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} AnythingFromAmerica.com — All rights reserved.</p>
      <p>Licensed U.S. Export Broker · Dallas, Texas</p>
    </div>
  </div>
</footer>

<style>
/* ----- Header ----- */
#site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--navy);
  border-bottom: 3px solid var(--red);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 68px;
  gap: 1rem;
}

.nav-logo {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 800;
  letter-spacing: -0.01em;
  color: var(--white);
  white-space: nowrap;
}
.logo-accent { color: var(--gold); }
.logo-dot { color: var(--gray-mid); }

.nav-links {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  list-style: none;
}

.nav-link {
  display: block;
  padding: 8px 14px;
  font-size: 14px;
  font-weight: 500;
  color: rgba(255,255,255,0.8);
  border-radius: var(--radius);
  transition: color 0.15s, background 0.15s;
}
.nav-link:hover { color: var(--white); background: rgba(255,255,255,0.07); }

.nav-cta { font-size: 13px; padding: 10px 20px; margin-left: 0.5rem; }

.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
}
.nav-toggle span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--white);
  border-radius: 2px;
  transition: all 0.2s;
}

@media (max-width: 768px) {
  .nav-toggle { display: flex; }
  .nav-links {
    display: none;
    position: absolute;
    top: 68px;
    left: 0; right: 0;
    background: var(--navy);
    flex-direction: column;
    align-items: stretch;
    padding: 1rem var(--pad-x) 1.5rem;
    gap: 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .nav-links.open { display: flex; }
  .nav-link { padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.07); border-radius: 0; }
  .nav-cta { margin: 1rem 0 0; text-align: center; justify-content: center; }
}

/* ----- Footer ----- */
.footer {
  background: var(--navy);
  color: rgba(255,255,255,0.75);
  padding: 4rem 0 2rem;
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 2.5rem;
  padding-bottom: 3rem;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

.footer-logo {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--white);
  margin-bottom: 0.75rem;
}
.footer-logo span { color: var(--gold); }

.footer-brand p {
  font-size: 14px;
  line-height: 1.65;
  margin-bottom: 1rem;
}

.footer-contact-row {
  display: flex;
  flex-direction: column;
  gap: 4px;
  font-size: 13px;
}
.footer-contact-row a { color: var(--gold); }
.footer-contact-row a:hover { text-decoration: underline; }

.footer-col h4 {
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--white);
  margin-bottom: 1rem;
}

.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.footer-col a { font-size: 14px; transition: color 0.15s; }
.footer-col a:hover { color: var(--white); }

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 1.5rem;
  font-size: 12px;
  gap: 1rem;
  flex-wrap: wrap;
}

@media (max-width: 900px) {
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .footer-brand { grid-column: 1 / -1; }
}
@media (max-width: 540px) {
  .footer-grid { grid-template-columns: 1fr; }
}
</style>

<script>
const toggle = document.getElementById('nav-toggle');
const links = document.getElementById('nav-links');
toggle?.addEventListener('click', () => {
  const open = links?.classList.toggle('open');
  toggle.setAttribute('aria-expanded', String(open));
});
</script>

</body>
</html>