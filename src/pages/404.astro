---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page Not Found" description="Page not found">
<section style="background:var(--navy);padding:6rem 0;text-align:center;border-bottom:3px solid var(--red)">
  <div class="container">
    <div style="font-family:var(--font-display);font-size:8rem;font-weight:800;color:var(--red);line-height:1">404</div>
    <h1 style="color:var(--white);font-size:2.5rem;margin-bottom:1rem">Page not found</h1>
    <p style="color:rgba(255,255,255,0.7);font-size:17px;margin-bottom:2rem">The page you're looking for doesn't exist.</p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
      <a href="/" class="btn btn-primary">Go home</a>
      <a href="/contact" class="btn btn-outline">Contact us</a>
    </div>
  </div>
</section>
</Layout>
