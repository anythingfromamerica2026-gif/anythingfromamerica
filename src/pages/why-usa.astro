---
import Layout from '../layouts/Layout.astro';

const reasons = [
  {
    icon: "🏆",
    title: "World-Class Quality",
    body: "American manufacturing standards are among the strictest in the world. Products made in the USA undergo rigorous quality control, safety testing, and certification processes — giving you confidence in every purchase."
  },
  {
    icon: "🔬",
    title: "Cutting-Edge Technology",
    body: "The USA leads global innovation in aerospace, medical technology, agriculture, and industrial equipment. Buying American means accessing the most advanced technology available anywhere on earth."
  },
  {
    icon: "⚖️",
    title: "Legal Certainty",
    body: "U.S. products come with clear intellectual property protections, standardized warranties, and enforceable consumer rights. No counterfeit risk — only genuine, certified products."
  },
  {
    icon: "🔧",
    title: "Parts & Support Availability",
    body: "American brands maintain global service networks and parts availability. Equipment bought through us can be serviced and maintained locally in most countries around the world."
  },
  {
    icon: "💰",
    title: "Strong Resale Value",
    body: "American-made products — especially aviation assets, heavy equipment, and vehicles — hold their value exceptionally well. Your purchase is an investment, not just an expense."
  },
  {
    icon: "🌍",
    title: "Global Compliance",
    body: "U.S. products meet or exceed international standards including ISO, CE, and industry-specific certifications. Less friction at customs, faster approval for use in your country."
  }
];

const stats = [
  { number: "$2T+", label: "U.S. exports annually" },
  { number: "#1", label: "Global aerospace manufacturer" },
  { number: "#1", label: "Medical device innovator" },
  { number: "60+", label: "Countries we serve" }
];
---

<Layout
  title="Why Buy From the USA?"
  description="Discover why global buyers trust American products — from aviation to industrial equipment. Quality, technology, legal certainty and strong resale value."
>

<section class="why-hero">
  <div class="container">
    <div class="section-label" style="color:var(--gold)">The American Advantage</div>
    <h1 class="section-title light">Why buy from<br>the USA?</h1>
    <p class="section-body light">Global buyers choose American products for a reason — quality, innovation, and trust that no other market can match.</p>
  </div>
</section>

<!-- Stats bar -->
<div class="stats-bar">
  <div class="container stats-inner">
    {stats.map(s => (
      <div class="stat-item">
        <strong>{s.number}</strong>
        <span>{s.label}</span>
      </div>
    ))}
  </div>
</div>

<!-- Reasons grid -->
<section class="section">
  <div class="container">
    <div class="reasons-header">
      <div class="section-label">6 Reasons to Buy American</div>
      <h2 class="section-title">The world buys from America<br>for good reason</h2>
    </div>
    <div class="reasons-grid">
      {reasons.map(r => (
        <div class="reason-card">
          <div class="reason-icon">{r.icon}</div>
          <h3>{r.title}</h3>
          <p>{r.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Industries section -->
<section class="section industries-section">
  <div class="container">
    <div class="section-label">Where USA Leads the World</div>
    <h2 class="section-title">America's strongest<br>export industries</h2>
    <div class="industries-grid">
      <div class="industry-card industry-card--large">
        <div class="industry-icon">✈️</div>
        <h3>Aerospace & Aviation</h3>
        <p>The USA manufactures more than 50% of the world's commercial aircraft and leads in general aviation. Boeing, Gulfstream, Cessna, and thousands of suppliers make America the undisputed leader in aviation technology.</p>
        <a href="/services#aviation" class="industry-link">Explore aviation exports →</a>
      </div>
      <div class="industry-card">
        <div class="industry-icon">🏥</div>
        <h3>Medical Technology</h3>
        <p>The U.S. medical device industry is the world's largest, with American companies holding more patents and FDA approvals than any other nation.</p>
        <a href="/services#medical" class="industry-link">Explore medical exports →</a>
      </div>
      <div class="industry-card">
        <div class="industry-icon">⚙️</div>
        <h3>Heavy Equipment</h3>
        <p>Caterpillar, John Deere, and hundreds of American manufacturers set the global standard for durability and reliability in construction and agriculture.</p>
        <a href="/services#industrial" class="industry-link">Explore industrial exports →</a>
      </div>
      <div class="industry-card">
        <div class="industry-icon">💻</div>
        <h3>Technology</h3>
        <p>From semiconductors to software, American tech companies dominate global markets. Hardware made in or designed by U.S. companies sets the world standard.</p>
        <a href="/services#consumer" class="industry-link">Explore tech exports →</a>
      </div>
      <div class="industry-card">
        <div class="industry-icon">🚗</div>
        <h3>Automotive</h3>
        <p>American trucks and SUVs are the most sought-after vehicles globally for their power, durability, and iconic status. Ford F-series leads global truck sales.</p>
        <a href="/services#automotive" class="industry-link">Explore auto exports →</a>
      </div>
    </div>
  </div>
</section>

<!-- Process comparison -->
<section class="section comparison-section">
  <div class="container">
    <div class="section-label">Why Use a Broker?</div>
    <h2 class="section-title">Buying direct vs.<br>using AnythingFromAmerica</h2>
    <div class="comparison-grid">
      <div class="comparison-col comparison-col--bad">
        <div class="comp-header">
          <span class="comp-icon">❌</span>
          <h3>Buying Direct (Without a Broker)</h3>
        </div>
        <ul>
          <li>Navigate complex U.S. export regulations alone</li>
          <li>Risk of dealing with unauthorized sellers</li>
          <li>No local support for customs clearance</li>
          <li>Full payment required upfront</li>
          <li>Shipping and logistics your responsibility</li>
          <li>No recourse if something goes wrong</li>
          <li>Language and time zone barriers</li>
        </ul>
      </div>
      <div class="comparison-col comparison-col--good">
        <div class="comp-header">
          <span class="comp-icon">✓</span>
          <h3>Using AnythingFromAmerica.com</h3>
        </div>
        <ul>
          <li>Full export compliance handled for you</li>
          <li>Verified U.S. suppliers and dealers only</li>
          <li>End-to-end customs documentation</li>
          <li>Buy Now, Pay Later financing available</li>
          <li>Complete shipping & freight management</li>
          <li>Dedicated point of contact throughout</li>
          <li>English support, Dallas TX business hours</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="cta-banner">
  <div class="container cta-inner">
    <div>
      <h2>Ready to buy from America?</h2>
      <p>Get a free quote within 24 hours — no commitment required.</p>
    </div>
    <div class="cta-actions">
      <a href="/contact" class="btn btn-primary">Get a Free Quote</a>
      <a href="/services" class="btn btn-outline">See What We Ship</a>
    </div>
  </div>
</section>

</Layout>

<style>
.why-hero {
  background: var(--navy);
  padding: clamp(2.5rem, 6vw, 4rem) 0;
  border-bottom: 3px solid var(--red);
}
.stats-bar {
  background: var(--red);
  padding: 1.5rem 0;
}
.stats-inner {
  display: flex;
  align-items: center;
  justify-content: space-around;
  gap: 2rem;
  flex-wrap: wrap;
}
.stat-item { text-align: center; }
.stat-item strong {
  display: block;
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 800;
  color: var(--white);
  line-height: 1;
}
.stat-item span {
  font-size: 13px;
  color: rgba(255,255,255,0.8);
}
.reasons-header { margin-bottom: 3rem; }
.reasons-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.reason-card {
  background: var(--white);
  border: 1px solid var(--gray-light);
  border-radius: var(--radius-lg);
  padding: 2rem;
  transition: box-shadow 0.18s, transform 0.18s;
}
.reason-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.08); transform: translateY(-2px); }
.reason-icon { font-size: 2.5rem; margin-bottom: 1rem; }
.reason-card h3 {
  font-family: var(--font-display);
  font-size: 1.4rem;
  color: var(--navy);
  margin-bottom: 0.75rem;
}
.reason-card p { font-size: 14px; color: var(--gray-dark); line-height: 1.7; }

.industries-section { background: var(--off-white); }
.industries-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin-top: 2.5rem;
}
.industry-card {
  background: var(--white);
  border: 1px solid var(--gray-light);
  border-radius: var(--radius-lg);
  padding: 1.75rem;
  transition: box-shadow 0.18s;
}
.industry-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
.industry-card--large {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 1.5rem;
  background: var(--navy);
  border-color: var(--navy);
}
.industry-card--large h3 { color: var(--white); }
.industry-card--large p { color: rgba(255,255,255,0.7); }
.industry-card--large .industry-link { color: var(--gold); white-space: nowrap; }
.industry-icon { font-size: 2rem; margin-bottom: 0.75rem; }
.industry-card--large .industry-icon { font-size: 3rem; margin-bottom: 0; }
.industry-card h3 {
  font-family: var(--font-display);
  font-size: 1.25rem;
  color: var(--navy);
  margin-bottom: 0.5rem;
}
.industry-card p { font-size: 14px; color: var(--gray-dark); line-height: 1.6; margin-bottom: 1rem; }
.industry-link { font-size: 13px; font-weight: 600; color: var(--red); }
.industry-link:hover { text-decoration: underline; }

.comparison-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  margin-top: 2.5rem;
}
.comparison-col {
  border-radius: var(--radius-lg);
  padding: 2rem;
}
.comparison-col--bad {
  background: #FEF2F2;
  border: 1px solid #FCA5A5;
}
.comparison-col--good {
  background: #ECFAF3;
  border: 1px solid #7EDBA8;
}
.comp-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 1.5rem;
}
.comp-icon { font-size: 1.5rem; }
.comp-header h3 {
  font-family: var(--font-display);
  font-size: 1.1rem;
  color: var(--navy);
}
.comparison-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.comparison-col li { font-size: 14px; color: var(--gray-dark); padding-left: 0; line-height: 1.5; }

.cta-banner { background: var(--red); padding: 3.5rem 0; }
.cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
.cta-inner h2 { font-size: clamp(1.75rem, 4vw, 2.5rem); color: var(--white); margin-bottom: 0.25rem; }
.cta-inner p { color: rgba(255,255,255,0.8); font-size: 15px; }
.cta-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

@media (max-width: 900px) {
  .reasons-grid { grid-template-columns: 1fr 1fr; }
  .industries-grid { grid-template-columns: 1fr 1fr; }
  .industry-card--large { grid-column: 1 / -1; grid-template-columns: 1fr; }
  .comparison-grid { grid-template-columns: 1fr; }
}
@media (max-width: 580px) {
  .reasons-grid { grid-template-columns: 1fr; }
  .industries-grid { grid-template-columns: 1fr; }
}
</style>
