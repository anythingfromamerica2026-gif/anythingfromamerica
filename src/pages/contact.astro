---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us — Get a Quote"
  description="Contact AnythingFromAmerica.com to request a quote on any U.S. product. We respond within 24 hours. Dallas, Texas. anythingfromamerica2026@gmail.com | +1-817-715-1156"
>

<section class="contact-hero">
  <div class="container">
    <div class="section-label" style="color:var(--gold)">We respond within 24 hours</div>
    <h1 class="section-title light">Get in touch</h1>
    <p class="section-body light">Tell us what you need from America and we'll send you a detailed quote — including sourcing, shipping, customs, and financing options.</p>
  </div>
</section>

<section class="section">
  <div class="container contact-grid">

    <div class="form-wrap">
      <h2 class="form-title">Request a quote</h2>
      <p class="form-note">All fields marked * are required. We'll reply to your email within 24 hours.</p>

      <form action="https://formspree.io/f/mqevbadv" method="POST" class="contact-form" id="contact-form">

        <div class="field-row">
          <div class="field">
            <label for="name">Full name *</label>
            <input type="text" id="name" name="name" required placeholder="Your full name" />
          </div>
          <div class="field">
            <label for="company">Company / Organization</label>
            <input type="text" id="company" name="company" placeholder="Your company name" />
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="email">Email address *</label>
            <input type="email" id="email" name="email" required placeholder="you@yourcompany.com" />
          </div>
          <div class="field">
            <label for="phone">Phone / WhatsApp</label>
            <input type="tel" id="phone" name="phone" placeholder="+1 or your country code" />
          </div>
        </div>

        <div class="field">
          <label for="country">Your country *</label>
          <input type="text" id="country" name="country" required placeholder="Where will goods be delivered?" />
        </div>

        <div class="field">
          <label for="product">What do you need? *</label>
          <input type="text" id="product" name="product" required placeholder="e.g. Cessna 172, John Deere tractor, Caterpillar parts..." />
        </div>

        <div class="field-row">
          <div class="field">
            <label for="quantity">Quantity</label>
            <input type="text" id="quantity" name="quantity" placeholder="e.g. 1 unit, 500 pieces" />
          </div>
          <div class="field">
            <label for="budget">Approximate budget (USD)</label>
            <select id="budget" name="budget">
              <option value="">Select a range</option>
              <option>Under $10,000</option>
              <option>$10,000 – $50,000</option>
              <option>$50,000 – $250,000</option>
              <option>$250,000 – $1,000,000</option>
              <option>Over $1,000,000</option>
            </select>
          </div>
        </div>

        <div class="field">
          <label>Interested in financing? (Buy Now, Pay Later)</label>
          <div class="radio-group">
            <label class="radio-label">
              <input type="radio" name="financing" value="yes" class="radio-input" />
              <span>Yes, I'd like financing options</span>
            </label>
            <label class="radio-label">
              <input type="radio" name="financing" value="no" class="radio-input" />
              <span>No, I'll pay in full</span>
            </label>
            <label class="radio-label">
              <input type="radio" name="financing" value="maybe" class="radio-input" />
              <span>Tell me more</span>
            </label>
          </div>
        </div>

        <div class="field">
          <label for="message">Additional details</label>
          <textarea id="message" name="message" rows="4" placeholder="Specifications, timeline, any other relevant details..."></textarea>
        </div>

        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        <input type="hidden" name="_subject" value="New inquiry from AnythingFromAmerica.com" />

        <button type="submit" class="btn btn-primary submit-btn">
          Send my inquiry →
        </button>

        <div id="form-success" class="form-success" style="display:none">
          <strong>Message received!</strong> We'll reply to your email within 24 hours.
        </div>
        <div id="form-error" class="form-error" style="display:none">
          Something went wrong. Please email us directly at <a href="mailto:anythingfromamerica2026@gmail.com">anythingfromamerica2026@gmail.com</a>
        </div>
      </form>
    </div>

    <aside class="contact-info">
      <div class="info-card">
        <div class="info-section">
          <div class="info-label">Email</div>
          <a href="mailto:anythingfromamerica2026@gmail.com" class="info-value">anythingfromamerica2026@gmail.com</a>
        </div>
        <div class="info-section">
          <div class="info-label">Phone / WhatsApp</div>
          <a href="tel:+18177151156" class="info-value">+1 (817) 715-1156</a>
        </div>
        <div class="info-section">
          <div class="info-label">Location</div>
          <div class="info-value">Dallas, Texas, USA</div>
        </div>
        <div class="info-section">
          <div class="info-label">Response time</div>
          <div class="info-value">Within 24 hours</div>
        </div>
      </div>

      <div class="info-card info-card--navy">
        <div class="info-badge">Buy Now · Pay Later</div>
        <h3>Need financing?</h3>
        <p>Ask us about flexible payment plans for orders over $50,000. We work with buyers in 60+ countries.</p>
        <ul>
          <li>20–30% down payment</li>
          <li>12–60 month terms</li>
          <li>Available for most product categories</li>
        </ul>
      </div>

      <div class="info-faq">
        <h3>Common questions</h3>
        <div class="faq-item">
          <strong>How fast do you respond?</strong>
          <p>Within 24 hours on business days. For urgent requests, call or WhatsApp us directly.</p>
        </div>
        <div class="faq-item">
          <strong>What countries do you ship to?</strong>
          <p>60+ countries worldwide. Contact us if you're unsure about yours.</p>
        </div>
        <div class="faq-item">
          <strong>Is there a minimum order size?</strong>
          <p>No minimum for regular purchases. Financing requires a minimum of $50,000.</p>
        </div>
      </div>
    </aside>
  </div>
</section>

</Layout>

<style>
.contact-hero {
  background: var(--navy);
  padding: clamp(2.5rem, 6vw, 4rem) 0;
  border-bottom: 3px solid var(--red);
}
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 3.5rem;
  align-items: start;
}
.form-wrap {
  background: var(--white);
  border: 1px solid #E4E3E0;
  border-radius: var(--radius-lg);
  padding: 2.5rem;
}
.form-title {
  font-family: var(--font-display);
  font-size: 2rem;
  color: var(--navy);
  margin-bottom: 0.5rem;
}
.form-note {
  font-size: 13px;
  color: var(--gray-mid);
  margin-bottom: 2rem;
}
.contact-form { display: flex; flex-direction: column; gap: 1.25rem; }
.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.field { display: flex; flex-direction: column; gap: 6px; }
.field label {
  font-size: 13px;
  font-weight: 600;
  color: var(--navy);
}
.field input:not(.radio-input),
.field select,
.field textarea {
  padding: 11px 14px;
  border: 1.5px solid #D8D7D4;
  border-radius: var(--radius);
  font-family: var(--font-body);
  font-size: 15px;
  color: var(--text);
  background: var(--white);
  transition: border-color 0.15s;
  width: 100%;
}
.field input:not(.radio-input):focus,
.field select:focus,
.field textarea:focus {
  outline: none;
  border-color: var(--navy);
}
.field textarea { resize: vertical; }

.radio-group {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 6px;
}
.radio-label {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: var(--gray-dark);
  cursor: pointer;
  padding: 0;
}
.radio-input {
  width: 16px;
  height: 16px;
  margin: 0;
  padding: 0;
  flex-shrink: 0;
  accent-color: var(--navy);
  cursor: pointer;
  border: none !important;
  background: none !important;
}

.submit-btn { margin-top: 0.5rem; justify-content: center; padding: 15px; font-size: 15px; }
.form-success {
  padding: 14px 16px;
  background: #ECFAF3;
  border: 1px solid #7EDBA8;
  border-radius: var(--radius);
  font-size: 14px;
  color: #1A6940;
}
.form-error {
  padding: 14px 16px;
  background: #FEF2F2;
  border: 1px solid #FCA5A5;
  border-radius: var(--radius);
  font-size: 14px;
  color: #991B1B;
}
.form-error a { color: var(--red); text-decoration: underline; }

.contact-info { display: flex; flex-direction: column; gap: 1.25rem; }
.info-card {
  background: var(--white);
  border: 1px solid #E4E3E0;
  border-radius: var(--radius-lg);
  padding: 1.75rem;
}
.info-card--navy {
  background: var(--navy);
  border-color: var(--navy);
  color: var(--white);
}
.info-section { margin-bottom: 1.25rem; }
.info-section:last-child { margin-bottom: 0; }
.info-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gray-mid);
  margin-bottom: 4px;
}
.info-card--navy .info-label { color: rgba(255,255,255,0.4); }
.info-value { font-size: 15px; color: var(--navy); font-weight: 500; }
a.info-value { color: var(--red); }
a.info-value:hover { text-decoration: underline; }
.info-badge {
  display: inline-block;
  padding: 4px 10px;
  background: var(--gold);
  color: var(--navy);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  border-radius: 2px;
  margin-bottom: 0.75rem;
}
.info-card--navy h3 { color: var(--white); font-size: 1.25rem; font-family: var(--font-display); margin-bottom: 0.5rem; }
.info-card--navy p { font-size: 14px; color: rgba(255,255,255,0.7); margin-bottom: 0.75rem; }
.info-card--navy ul { list-style: none; display: flex; flex-direction: column; gap: 4px; }
.info-card--navy li {
  font-size: 13px;
  color: rgba(255,255,255,0.65);
  padding-left: 1rem;
  position: relative;
}
.info-card--navy li::before { content: '✓'; position: absolute; left: 0; color: var(--gold); font-size: 11px; top: 2px; }
.info-faq {
  background: var(--off-white);
  border-radius: var(--radius-lg);
  padding: 1.75rem;
}
.info-faq h3 { font-family: var(--font-display); font-size: 1.1rem; color: var(--navy); margin-bottom: 1rem; }
.faq-item { margin-bottom: 1rem; }
.faq-item:last-child { margin-bottom: 0; }
.faq-item strong { display: block; font-size: 13px; color: var(--navy); margin-bottom: 3px; }
.faq-item p { font-size: 13px; color: var(--gray-dark); line-height: 1.55; }

@media (max-width: 860px) {
  .contact-grid { grid-template-columns: 1fr; }
  .field-row { grid-template-columns: 1fr; }
}
</style>

<script>
const form = document.getElementById('contact-form') as HTMLFormElement;
const success = document.getElementById('form-success');
const errorDiv = document.getElementById('form-error');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
  btn.textContent = 'Sending...';
  btn.disabled = true;
  try {
    const res = await fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { Accept: 'application/json' }
    });
    const json = await res.json();
    if (res.ok) {
      form.reset();
      if (success) success.style.display = 'block';
      if (errorDiv) errorDiv.style.display = 'none';
    } else {
      if (errorDiv) {
        errorDiv.style.display = 'block';
        const msg = json?.errors?.map((e: any) => e.message).join(', ') || json?.error || String(res.status);
        errorDiv.innerHTML = 'Error: ' + msg + '. Please email <a href="mailto:anythingfromamerica2026@gmail.com">anythingfromamerica2026@gmail.com</a>';
      }
    }
  } catch(err) {
    if (errorDiv) {
      errorDiv.style.display = 'block';
      errorDiv.innerHTML = 'Could not send. Please email <a href="mailto:anythingfromamerica2026@gmail.com">anythingfromamerica2026@gmail.com</a>';
    }
  } finally {
    btn.textContent = 'Send my inquiry →';
    btn.disabled = false;
  }
});
</script>
